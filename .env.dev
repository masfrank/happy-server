# Node 环境
NODE_ENV=development

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/happy-server
POSTGRES_DB=happy-server
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis 配置
REDIS_URL=redis://redis:6379

# 应用配置
PORT=3005
SEED=xxx
HANDY_MASTER_SECRET=xxx

# 时区配置
TZ=Asia/Shanghai

# 监控配置
METRICS_ENABLED=true
METRICS_PORT=9090

# 调试配置
DANGEROUSLY_LOG_TO_SERVER_FOR_AI_AUTO_DEBUGGING=true

# MinIO/S3 配置
MINIO_ROOT_USER=xxx
MINIO_ROOT_PASSWORD=xxx
S3_HOST=minio
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=xxx
S3_SECRET_KEY=xxx
S3_BUCKET=happy
S3_PUBLIC_URL=http://localhost:9000/happy