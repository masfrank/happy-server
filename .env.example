# =============================================================================
# happy-server — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Generate HANDY_MASTER_SECRET:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# Master secret for end-to-end encryption (keep this private, never rotate it)
HANDY_MASTER_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection URL
DATABASE_URL=postgresql://happy:password@postgres:5432/happy-server

# Credentials used by the postgres service in docker-compose.yml
POSTGRES_DB=happy-server
POSTGRES_USER=happy
POSTGRES_PASSWORD=change-me

# ── Redis ─────────────────────────────────────────────────────────────────────

# Redis connection URL (optional — disables pub/sub clustering if omitted)
REDIS_URL=redis://redis:6379

# ── Server ────────────────────────────────────────────────────────────────────

PORT=3005
NODE_ENV=production
TZ=UTC

# ── File Storage (optional — uses local disk if not set) ──────────────────────

# S3_HOST=s3.example.com
# S3_PORT=443
# S3_USE_SSL=true
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=happy-server
# S3_PUBLIC_URL=https://cdn.example.com

# ── Optional integrations ─────────────────────────────────────────────────────

# ELEVENLABS_API_KEY=
# REVENUECAT_API_KEY=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=
# GITHUB_REDIRECT_URL=

# ── Metrics (optional) ────────────────────────────────────────────────────────

# METRICS_ENABLED=true
# METRICS_PORT=9090

# ── Debug (optional) ──────────────────────────────────────────────────────────

# DANGEROUSLY_LOG_TO_SERVER_FOR_AI_AUTO_DEBUGGING=true
