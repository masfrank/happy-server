# Master secret for end-to-end encryption (keep this private, never rotate it)
HANDY_MASTER_SECRET=
# PostgreSQL connection URL
DATABASE_URL=postgresql://happy:password@postgres:5432/happy-server
POSTGRES_DB=happy-server
POSTGRES_USER=happy
POSTGRES_PASSWORD=change-me

# ── Redis
REDIS_URL=redis://redis:6379

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3005
NODE_ENV=production
TZ=UTC

# ── Optional integrations ─────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=
# REVENUECAT_API_KEY=

# ── Debug (optional) ──────────────────────────────────────────────────────────
# DANGEROUSLY_LOG_TO_SERVER_FOR_AI_AUTO_DEBUGGING=true
